{% from "components/_link.njk" import link %}

{#
  Hero
  A full-width banner with an optional background image, heading, lead text, and action link.

  heading      string  The main heading text.
  lead         string  Optional. Supporting lead paragraph.
  image        string  Optional. Path to a local source image for the background.
  imageWidths  array   Optional. Array of widths to generate for the srcset.
  imageSizes   string  Optional. The `sizes` attribute for the background image. Default: 100vw.
  actionText   string  Optional. Label for the call-to-action link.
  actionHref   string  Optional. URL for the call-to-action link. Default: #.

  {{ hero(article.title, lead=article.standfirst, image=article.heroImage, imageWidths=[800, 1440, 2000], actionText="Find out more", actionHref=article.ctaUrl) }}
#}
{% macro hero(heading, lead="", image="", imageWidths=[], imageSizes="100vw", actionText="", actionHref="#") %}
<div class="u-hero">
  {% if image and imageWidths %}
    <img src="{{ image }}" eleventy:widths="{{ imageWidths | join(',') }}" sizes="{{ imageSizes }}" alt="" aria-hidden="true" class="u-hero__bg-image">
  {% endif %}
  <div class="wrapper">
    <div class="u-hero__content">
      <h1 class="u-hero__heading">{{ heading }}</h1>
      {% if lead %}
        <p class="u-hero__lead">{{ lead }}</p>
      {% endif %}
      {% if actionText %}
        {{ link(actionText, actionHref) }}
      {% endif %}
    </div>
  </div>
</div>
{% endmacro %}
